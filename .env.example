# VaultLayer optional backend configuration
#
# Local SQLite is the compatibility default and requires no secrets.
# Runtime DB/index files are written outside the repo and outside the source vault.
#   ~/.local/share/vault-layer/

# Optional local runtime state override.
# VAULT_LAYER_STATE_DIR=/home/you/.local/share/vault-layer

# Local open-source Turso-compatible DB: libSQL embedded, no URL/token/network.
# VAULT_LAYER_BACKEND=libsql-local

# Optional remote Turso/libSQL sync. Remote writes only happen when you explicitly
# run `sync-turso` or pass `index --remote-sync`. Never commit real values.
# VAULT_LAYER_BACKEND=turso-remote
# TURSO_DATABASE_URL=libsql://your-database.turso.io
# TURSO_AUTH_TOKEN=replace-with-local-secret-only
