# VaultLayer optional backend configuration
#
# Local SQLite is the default and requires no secrets. Runtime DB/index files are
# written outside the repo and outside the source vault, normally under:
#   ~/.local/share/vault-layer/

# Optional local runtime state override.
# VAULT_LAYER_STATE_DIR=/home/you/.local/share/vault-layer

# Optional Turso/libSQL remote target. Setting this only records/configures the
# remote backend today; index writes stay local until explicit remote sync is
# implemented, so private vault text is not uploaded accidentally.
# TURSO_DATABASE_URL=libsql://your-db-org.turso.io
# TURSO_AUTH_TOKEN=replace-with-local-secret-only
