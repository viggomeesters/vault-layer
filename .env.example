# VaultLayer optional backend configuration
#
# SQLite + FTS5 is the recommended/default local retrieval backend. Runtime DB/index
# files are written outside the repo and outside the source vault:
#   ~/.local/share/vault-layer/

# Optional local runtime state override.
# VAULT_LAYER_STATE_DIR=/home/you/.local/share/vault-layer

# Recommended/default local retrieval backend.
# VAULT_LAYER_BACKEND=sqlite

# Optional analytics/export sidecar: DuckDB projection.
# VAULT_LAYER_BACKEND=duckdb

# Experimental local open-source Turso-compatible DB: embedded libSQL.
# VAULT_LAYER_BACKEND=libsql-local

# Optional hosted Turso/libSQL sync. Remote writes only happen when you explicitly
# run `sync-turso` or pass `index --remote-sync`. Never commit real values.
# VAULT_LAYER_BACKEND=turso-remote
# TURSO_DATABASE_URL=libsql://your-database.turso.io
# TURSO_AUTH_TOKEN=replace-with-local-secret-only
